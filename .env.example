# Database
DATABASE_URL=postgresql://proj_app:proj_app@postgres:5432/projtest
MIGRATION_DATABASE_URL=postgresql://proj:proj@postgres:5432/projtest

# Redis
REDIS_URL=redis://redis:6379

# Auth
AUTH_SECRET=change-me-to-a-random-32-char-string-in-production
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3001

# Email (Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@projtest.local

# OAuth (optional — enable in production)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Uploads
UPLOAD_DIR=/data/uploads

# Stripe billing (optional — enable for checkout in production)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=

# Vtiger CRM (optional — dev stack includes a local Vtiger container)
# Docker dev defaults (no .env changes needed):
#   VTIGER_BASE_URL=http://vtiger
#   VTIGER_PUBLIC_URL=http://localhost:8080
#   VTIGER_USERNAME=admin
#   VTIGER_ACCESS_KEY=projtest-dev-vtiger-key
# Vtiger web UI: http://localhost:8080 (login admin / admin)
VTIGER_BASE_URL=http://vtiger
VTIGER_PUBLIC_URL=http://localhost:8080
VTIGER_USERNAME=admin
VTIGER_ACCESS_KEY=projtest-dev-vtiger-key
# Default true — workspaces without saved credentials use VTIGER_* env vars (local Docker dev only)
# Set false in production multi-tenant SaaS
VTIGER_SINGLE_TENANT_MODE=true

# App
NODE_ENV=development

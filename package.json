    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:docker": "docker compose --profile dev exec -T app ./node_modules/.bin/tsx scripts/run-e2e.ts",
    "test:system": "tsx scripts/system-test.ts",
    "phase:gate": "tsx scripts/phase-gate.ts",
    "phase:status": "tsx scripts/phase-gate.ts --status"
  },

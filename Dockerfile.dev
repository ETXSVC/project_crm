FROM node:20-bookworm-slim
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends netcat-openbsd socat && rm -rf /var/lib/apt/lists/*

COPY package.json pnpm-lock.yaml* package-lock.json* ./
RUN pnpm install

# Browsers for in-container E2E (optional: pnpm test:e2e inside container)
RUN pnpm exec playwright install --with-deps chromium

COPY . .

RUN chmod +x docker/entrypoint.sh docker/wait-for-it.sh && \
    sed -i 's/\r$//' docker/entrypoint.sh docker/wait-for-it.sh

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["/app/docker/entrypoint.sh"]
CMD ["pnpm", "dev"]
